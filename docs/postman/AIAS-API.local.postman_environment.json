{
  "id": "aias-api-local-env",
  "name": "AIAS API — Local",
  "values": [
    {
      "key": "central_base_url",
      "value": "http://127.0.0.1:8088/api/v1",
      "type": "default",
      "enabled": true,
      "description": "Central domain. Start server: php artisan serve --host=127.0.0.1 --port=8088"
    },
    {
      "key": "tenant_base_url",
      "value": "http://{{tenant_id}}.localhost:8088/v1",
      "type": "default",
      "enabled": true,
      "description": "Tenant domain. Resolved from tenant_id variable. Requires /etc/hosts or local DNS for subdomain routing."
    },
    {
      "key": "tenant_id",
      "value": "acme-corp",
      "type": "default",
      "enabled": true,
      "description": "Active tenant slug. Must match a tenant in the database."
    },
    {
      "key": "sa_token",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "Super-admin Bearer token. Auto-set by SA Login."
    },
    {
      "key": "tenant_token",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "Tenant user Bearer token. Auto-set by Tenant Login/Register."
    },
    {
      "key": "sa_email",
      "value": "sa@aias.system",
      "type": "default",
      "enabled": true,
      "description": "Default super-admin email (seeded by DatabaseSeeder)."
    },
    {
      "key": "sa_password",
      "value": "password",
      "type": "secret",
      "enabled": true,
      "description": "Default super-admin password (seeded by DatabaseSeeder)."
    }
  ],
  "_postman_variable_scope": "environment",
  "_postman_exported_at": "2026-05-17T00:00:00.000Z",
  "_postman_exported_using": "jq/1.7.1"
}
