{
    "hooks": {
        "SessionStart": [
            {
                "type": "command",
                "command": "./.github/hooks/scripts/load-feedback-memory.mjs",
                "timeout": 10
            }
        ],
        "UserPromptSubmit": [
            {
                "type": "command",
                "command": "./.github/hooks/scripts/load-feedback-memory.mjs",
                "timeout": 10
            }
        ],
        "PreCompact": [
            {
                "type": "command",
                "command": "./.github/hooks/scripts/capture-feedback-memory.mjs",
                "timeout": 10
            }
        ],
        "Stop": [
            {
                "type": "command",
                "command": "./.github/hooks/scripts/capture-feedback-memory.mjs",
                "timeout": 10
            }
        ]
    }
}
