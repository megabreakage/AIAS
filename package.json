{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "docs:export": "php artisan scramble:export --path=storage/api-docs/openapi.json",
        "docs:build": "npm run docs:export && npx @redocly/cli build-docs storage/api-docs/openapi.json --output=public/docs/index.html",
        "docs:preview": "npx @redocly/cli preview-docs storage/api-docs/openapi.json"
    },
    "devDependencies": {
        "@redocly/cli": "^1.34.15",
        "@tailwindcss/vite": "^4.0.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.1",
        "tailwindcss": "^4.0.0",
        "vite": "^8.0.0"
    }
}
